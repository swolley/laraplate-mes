{
    "name": "swolley/laraplate-mes",
    "vendor": "swolley",
    "description": "MES module for Laraplate: manufacturing execution system.",
    "version": "v1.0.0",
    "keywords": [
        "laravel",
        "laraplate",
        "mes"
    ],
    "authors": [
        {
            "name": "Swolley",
            "email": "myentity@inwind.it"
        }
    ],
    "license": "AGPL-3.0-or-later",
    "type": "laravel-module",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/swolley/license-compliance-checker.git",
            "no-api": true
        }
    ],
    "require": {
        "php": ">=8.5",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "swolley/license-compliance-checker": "dev-master",
        "laravel/pint": "^1.13",
        "nunomaduro/phpinsights": "^2.13",
        "peckphp/peck": "^0.1.3",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-stressless": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.0",
        "larastan/larastan": "^3.9",
        "dg/bypass-finals": "^1.9",
        "driftingly/rector-laravel": "^2.2",
        "filament/filament": "^5.0"
    },
    "scripts": {
        "lint": [
            "rector",
            "pint --parallel",
            "php artisan ide-helper:generate",
            "php artisan ide-helper:models -MN",
            "php artisan ide-helper:meta"
        ],
        "check": "vendor/bin/phpstan analyse --memory-limit=2G -v",
        "fix": "vendor/bin/phpstan analyse --memory-limit=2G -v --fix",
        "refactor": "rector",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:typos": "peck",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:unit": "vendor/bin/pest --coverage --exactly=100",
        "test:unit:parallel": "vendor/bin/pest --parallel --coverage --exactly=100",
        "test:types": "phpstan",
        "test:refactor": "rector",
        "test:licenses": "@php vendor/bin/check-licenses",
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types",
            "@test:refactor",
            "@test:licenses"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "version": "./scripts/version.sh --nointeractive",
        "version:silent": "./scripts/version.sh --silent --nointeractive",
        "version:major": "./scripts/version.sh major",
        "version:minor": "./scripts/version.sh minor",
        "version:patch": "./scripts/version.sh patch",
        "setup:hooks": "./scripts/setup-hooks.sh"
    },
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {}
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\MES\\": "app/",
            "Modules\\MES\\Database\\Factories\\": "database/factories/",
            "Modules\\MES\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\MES\\Tests\\Unit\\": "tests/Unit",
            "Modules\\MES\\Tests\\Feature\\": "tests/Feature"
        },
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}